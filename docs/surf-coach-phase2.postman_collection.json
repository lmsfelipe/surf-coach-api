                  "pm.test('sessionId matches', () => pm.expect(pm.response.json().sessionId).to.eql(pm.collectionVariables.get('SESSION_ID')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{API_URL}}/api/v1/sessions/{{SESSION_ID}}/review",
              "host": ["{{API_URL}}"],
              "path": ["api", "v1", "sessions", "{{SESSION_ID}}", "review"]
            }
          }
        },
        {
          "name": "POST /api/v1/reviews/ — duplicate (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 409', () => pm.response.to.have.status(409));",
                  "pm.test('REVIEW_ALREADY_EXISTS code', () => pm.expect(pm.response.json().error.code).to.eql('REVIEW_ALREADY_EXISTS'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
