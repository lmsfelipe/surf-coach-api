{
  "info": {
    "name": "Surf Coach — Phase 2",
    "description": "Full Phase 2 flow: sessions CRUD, media upload, AI review generation and retrieval. Run requests top-to-bottom; test scripts auto-populate SESSION_ID, MEDIA_ID, and REVIEW_ID.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "b2c3d4e5-f6a7-8901-2345-678901bcdef0"
  },
  "variable": [
    {
      "key": "SUPABASE_URL",
      "value": "https://your-project-ref.supabase.co",
      "description": "Your Supabase project URL"
    },
    {
      "key": "SUPABASE_ANON_KEY",
      "value": "",
      "description": "Supabase anon key from Dashboard → Settings → API"
    },
    {
      "key": "API_URL",
      "value": "http://localhost:8000",
      "description": "Local FastAPI base URL"
    },
    {
      "key": "ACCESS_TOKEN",
      "value": "",
      "description": "Populated automatically by Login request"
    },
    {
      "key": "USER_EMAIL",
      "value": "surfer@example.com"
    },
    {
      "key": "USER_PASSWORD",
      "value": "SuperSecret123!"
    },
    {
      "key": "SESSION_ID",
      "value": "",
      "description": "Populated automatically by Create Session request"
    },
    {
      "key": "MEDIA_ID",
      "value": "",
      "description": "Populated automatically by Upload Media request"
    },
    {
      "key": "REVIEW_ID",
      "value": "",
      "description": "Populated automatically by Generate Review request"
    }
  ],
  "item": [
    {
      "name": "0 — Sanity",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ok body', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/health",
              "host": ["{{API_URL}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "1 — Auth",
      "item": [
        {
          "name": "Supabase — Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('ACCESS_TOKEN', json.access_token);",
                  "  pm.test('got token', () => pm.expect(json.access_token).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{SUPABASE_ANON_KEY}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{SUPABASE_URL}}/auth/v1/signup",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["auth", "v1", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{USER_EMAIL}}\",\n  \"password\": \"{{USER_PASSWORD}}\"\n}"
            }
          }
        },
        {
          "name": "Supabase — Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('got token', () => pm.expect(json.access_token).to.be.a('string'));",
                  "pm.collectionVariables.set('ACCESS_TOKEN', json.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{SUPABASE_ANON_KEY}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{SUPABASE_URL}}/auth/v1/token?grant_type=password",
              "host": ["{{SUPABASE_URL}}"],
              "path": ["auth", "v1", "token"],
              "query": [{ "key": "grant_type", "value": "password" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{USER_EMAIL}}\",\n  \"password\": \"{{USER_PASSWORD}}\"\n}"
            }
          }
        },
        {
          "name": "GET /me — Phase 1 still works",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('has surfLevel', () => pm.expect(pm.response.json()).to.have.property('surfLevel'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{API_URL}}/me",
              "host": ["{{API_URL}}"],
              "path": ["me"]
            }
          }
        }
      ]
    },
    {
      "name": "2 — Sessions",
      "item": [
        {
          "name": "POST /api/v1/sessions/ — create",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('has id', () => pm.expect(json.id).to.be.a('string'));",
                  "pm.test('sessionDate correct', () => pm.expect(json.sessionDate).to.eql('2026-04-22'));",
                  "pm.collectionVariables.set('SESSION_ID', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{API_URL}}/api/v1/sessions/",
              "host": ["{{API_URL}}"],
              "path": ["api", "v1", "sessions", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionDate\": \"2026-04-22\",\n  \"location\": \"Praia de Santos\",\n  \"waveConditions\": \"overhead, clean, SW swell\",\n  \"boardType\": \"shortboard 6'2\\\"\",\n  \"notes\": \"Felt good on the bigger sets\"\n}"
            }
          }
        },
        {
          "name": "GET /api/v1/sessions/ — list",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('is array', () => pm.expect(json).to.be.an('array'));",
                  "pm.test('contains created session', () => {",
                  "  const sid = pm.collectionVariables.get('SESSION_ID');",
                  "  pm.expect(json.some(s => s.id === sid)).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{API_URL}}/api/v1/sessions/",
              "host": ["{{API_URL}}"],
              "path": ["api", "v1", "sessions", ""]
            }
          }
        },
        {
          "name": "GET /api/v1/sessions/:id — detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('correct id', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('SESSION_ID')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{API_URL}}/api/v1/sessions/{{SESSION_ID}}",
              "host": ["{{API_URL}}"],
              "path": ["api", "v1", "sessions", "{{SESSION_ID}}"]
            }
          }
        },
        {
          "name": "POST /api/v1/sessions/ — missing required field (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('VALIDATION_ERROR code', () => pm.expect(pm.response.json().error.code).to.eql('VALIDATION_ERROR'));"
                ]
              }
            }
