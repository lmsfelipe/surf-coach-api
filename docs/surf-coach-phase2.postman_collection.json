    {
      "name": "4 — Reviews",
      "item": [
        {
          "name": "POST /api/v1/reviews/ — generate AI review",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('has narrative', () => pm.expect(json.narrative).to.be.a('string').and.not.empty);",
                  "pm.test('exactly 3 improvement tips', () => pm.expect(json.improvementTips).to.have.lengthOf(3));",
                  "pm.test('overallScore is mean of 6 scores', () => {",
                  "  const mean = parseFloat(",
                  "    ((json.scoreFlow + json.scoreDrop + json.scoreBalance +",
                  "      json.scoreWaveSelection + json.scoreManeuvers + json.scoreArms) / 6).toFixed(1)",
                  "  );",
                  "  pm.expect(json.overallScore).to.be.closeTo(mean, 0.1);",
                  "});",
                  "pm.collectionVariables.set('REVIEW_ID', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{API_URL}}/api/v1/reviews/",
              "host": ["{{API_URL}}"],
              "path": ["api", "v1", "reviews", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{SESSION_ID}}\"\n}"
            }
          }
        },
        {
          "name": "GET /api/v1/reviews/:id — get by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('correct id', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('REVIEW_ID')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{API_URL}}/api/v1/reviews/{{REVIEW_ID}}",
              "host": ["{{API_URL}}"],
              "path": ["api", "v1", "reviews", "{{REVIEW_ID}}"]
            }
          }
